# ===== LLM (model-agnostic — swap via these vars) =====
LLM_PROVIDER=anthropic          # anthropic | openai | google | bedrock | ollama
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ===== Web search (Clark: pick provider + key) =====
SEARCH_PROVIDER=brave           # brave | serper | bing
SEARCH_API_KEY=
SEARCH_CACHE_TTL_SECONDS=180
SEARCH_RATE_LIMIT_PER_MIN=10

# ===== ASR / TTS =====
WHISPER_MODEL=base              # tiny | base | small | medium
TTS_PROVIDER=openai             # openai | elevenlabs | polly
TTS_API_KEY=

# ===== RAG =====
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE=chroma             # chroma | faiss
CHROMA_DIR=./data/index
RERANKER_ENABLED=false

# ===== MCP server =====
MCP_TRANSPORT=stdio             # stdio | http
MCP_LOG_FILE=./logs/mcp_tools.jsonl
